DATABASE_URL=postgres://accessflow:accessflow@localhost:55433/accessflow
# Optional override for `pnpm mobile:preview`. Must still point to the local
# preview database, not a shared or production database.
ACCESSFLOW_PREVIEW_DATABASE_URL=postgres://accessflow:accessflow@localhost:55433/accessflow
# Optional override for the API test runner. Defaults to the same server with
# the database name suffixed as accessflow_test.
ACCESSFLOW_TEST_DATABASE_URL=postgres://accessflow:accessflow@localhost:55433/accessflow_test
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
BETTER_AUTH_URL=http://localhost:4000
BETTER_AUTH_SECRET=development-only-change-me-development-only
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info
